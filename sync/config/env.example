REPO_OWNER=syncthing
REPO_NAME=syncthing
DOWNLOAD_ROOT=./data/releases
KEEP_VERSIONS=3
RELEASE_COUNT=3
SYNC_PROFILE=windows
ASSET_MATCH=
FORCE_DOWNLOAD=0
MIRROR_BASE_URL=https://download.example.com/syncthing
REMOTE_HOST=example.com
REMOTE_USER=deploy
REMOTE_PATH=/var/www/downloads/syncthing
REMOTE_PORT=22
DRY_RUN=0
PUBLISH_LAYOUT=versioned
STAGE_ROOT=
SYNC_REFRESH_PUBLISH_HOST_KEY=0

SYNC_DEPLOY_HOST=ubuntu24.example.com
SYNC_DEPLOY_USER=deploy
SYNC_DEPLOY_PORT=22
SYNC_DEPLOY_BASE_DIR=/opt/syncthing-installer-sync
SYNC_SYSTEMD_NAME_PREFIX=syncthing-installer-sync
SYNC_RUN_USER=deploy
SYNC_RUN_GROUP=deploy
SYNC_TIMER_ON_CALENDAR=hourly